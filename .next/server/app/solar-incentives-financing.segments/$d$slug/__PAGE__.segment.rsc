18:Tbd3,{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"Is there currently an Alberta residential solar rebate?","acceptedAnswer":{"@type":"Answer","text":"Alberta does not currently offer a universal provincial residential solar rebate. Municipal programs, financing and other opportunities can depend on the applicant, property, municipality and current intake."}},{"@type":"Question","name":"Is Calgary CEIP a rebate or a loan?","acceptedAnswer":{"@type":"Answer","text":"CEIP is property-based financing, not a rebate. Approved financing is repaid through the property tax bill under the program agreement."}},{"@type":"Question","name":"Can I begin installation before CEIP approval?","acceptedAnswer":{"@type":"Answer","text":"No. Calgary states that the application must be approved and the Clean Energy Improvement Agreement entered before work begins for CEIP financing."}},{"@type":"Question","name":"Will solar remove every charge from my electricity bill?","acceptedAnswer":{"@type":"Answer","text":"No. Electricity used on-site can reduce grid consumption, but distribution, transmission, local access and other charges can remain."}},{"@type":"Question","name":"How are exported solar credits calculated?","acceptedAnswer":{"@type":"Answer","text":"For micro-generation, excess electricity supplied to the grid is credited by the retailer. Retailer rates, terms and billing arrangements should be confirmed directly with that retailer."}},{"@type":"Question","name":"Can farms qualify for solar incentives?","acceptedAnswer":{"@type":"Answer","text":"Farm eligibility depends on the property, business structure, utility arrangement, land classification and current program rules. Farms should not assume a grant or financing program applies automatically."}},{"@type":"Question","name":"Can a business claim the Clean Technology ITC?","acceptedAnswer":{"@type":"Answer","text":"Qualifying new clean-technology property may be eligible for a refundable federal credit, subject to detailed ownership, tax-status, acquisition and use requirements. A Canadian tax professional should confirm eligibility."}},{"@type":"Question","name":"Can I combine financing with a tax incentive?","acceptedAnswer":{"@type":"Answer","text":"It may be possible in some situations, but financing terms and tax eligibility are separate decisions. Confirm lender, program and tax treatment before relying on any combination."}},{"@type":"Question","name":"What happens to CEIP financing if the property is sold?","acceptedAnswer":{"@type":"Answer","text":"CEIP financing is attached to the property. The owner may be able to repay the balance or disclose and transfer it to a new owner, subject to the program agreement."}},{"@type":"Question","name":"How often should incentive information be reviewed?","acceptedAnswer":{"@type":"Answer","text":"Review it before design, before signing a contract and again before an application. Intake, eligibility, retailer terms and tax rules can change."}}]}14:["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$18"}}]
