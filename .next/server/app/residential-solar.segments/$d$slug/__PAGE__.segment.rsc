10:T7f5,{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"How do I know whether my roof gets enough sunlight for solar?","acceptedAnswer":{"@type":"Answer","text":"Roof direction, pitch, nearby trees, chimneys, neighbouring buildings and usable roof area all matter. A property-specific shade and layout review is more useful than judging the roof from street level."}},{"@type":"Question","name":"Can panels be installed on more than one side of my roof?","acceptedAnswer":{"@type":"Answer","text":"Yes. Multiple roof planes can be used when the layout, shading and electrical design make sense. The proposal should explain how each roof section contributes to estimated annual production."}},{"@type":"Question","name":"Should I size solar for an electric vehicle I plan to buy?","acceptedAnswer":{"@type":"Answer","text":"Future electricity use can be considered when it is reasonably understood. Expected driving, charging habits and other planned loads should be discussed before final system sizing."}},{"@type":"Question","name":"What if I sell my home after installing solar?","acceptedAnswer":{"@type":"Answer","text":"The system, warranties, financing and utility arrangements should be documented clearly. Speak with your real-estate and legal professionals about how ownership or financing would be handled during a sale."}},{"@type":"Question","name":"Will installation damage my shingles or cause roof leaks?","acceptedAnswer":{"@type":"Answer","text":"A responsible design uses mounting and flashing methods suited to the roof type and condition. Roof condition, attachment locations and waterproofing details should be reviewed before work begins."}},{"@type":"Question","name":"Can I add a battery later?","acceptedAnswer":{"@type":"Answer","text":"Sometimes. Future battery readiness depends on the inverter, electrical design, available space and the equipment ecosystem selected. Mention this goal during the initial assessment even if a battery is not part of the first phase."}}]}b:["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$10"}}]
