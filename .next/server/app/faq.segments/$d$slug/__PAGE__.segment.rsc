c:["$","section",null,{"className":"faq-page-final","children":[["$","div",null,{"className":"faq-page-final-rays","aria-hidden":"true"}],["$","div",null,{"className":"container","children":[["$","div",null,{"children":[["$","p",null,{"className":"kicker light","children":"A property-specific answer"}],["$","h2",null,{"children":"Get Answers Based on Your Actual Property"}],["$","p",null,{"children":"Share your electricity usage and property details, and we’ll prepare a solar assessment based on your specific needs."}]]}],["$","div",null,{"className":"faq-page-final-actions","children":[["$","$L3",null,{"className":"button ","href":"/free-solar-assessment","children":["Start My Solar Assessment",["$","svg",null,{"aria-hidden":"true","className":"","fill":"none","viewBox":"0 0 24 24","stroke":"currentColor","strokeWidth":"1.8","strokeLinecap":"round","strokeLinejoin":"round","children":[["$","path",null,{"d":"M5 12h14"}],["$","path",null,{"d":"m13 6 6 6-6 6"}]]}]]}],["$","$L3",null,{"className":"button button-secondary","href":"/contact","children":["Contact Sun Direct Renewable",["$","svg",null,{"aria-hidden":"true","className":"","fill":"none","viewBox":"0 0 24 24","stroke":"currentColor","strokeWidth":"1.8","strokeLinecap":"round","strokeLinejoin":"round","children":[["$","path",null,{"d":"M5 12h14"}],["$","path",null,{"d":"m13 6 6 6-6 6"}]]}]]}]]}]]}]]}]
