container","aria-label":"Breadcrumb","children":[["$","$L3",null,{"href":"/","children":"Home"}],["$","span",null,{"children":"/"}],["$","span",null,{"aria-current":"page","children":"Solar Frequently Asked Questions"}]]}],["$","section",null,{"className":"section faq-page-intro","children":["$","div",null,{"className":"container","children":[["$","div",null,{"className":"faq-page-heading","children":[["$","p",null,{"className":"kicker","children":"Answers built around Alberta solar planning"}],["$","h2",null,{"children":"Start with the question that matters to your property."}],["$","p",null,{"children":"These answers explain the practical issues that shape a solar project. Your final system, timing and financial options still need a review of your property, electricity usage and current requirements."}]]}],["$","div",null,{"className":"faq-topic-cards","children":[["$","a",null,{"href":"#questions","children":[["$","svg",null,{"aria-hidden":"true","className":"","fill":"none","viewBox":"0 0 24 24","stroke":"currentColor","strokeWidth":"1.8","strokeLinecap":"round","strokeLinejoin":"round","children":[["$","path",null,{"d":"m3 11 9-8 9 8"}],["$","path",null,{"d":"M5 10v10h14V10M9 20v-6h6v6"}]]}],["$","strong",null,{"children":"Homes & rooftops"}],["$","span",null,{"children":"Suitability, sizing and roof planning"}]]}],["$","a",null,{"href":"#questions","children":[["$","svg",null,{"aria-hidden":"true","className":"","fill":"none","viewBox":"0 0 24 24","stroke":"currentColor","strokeWidth":"1.8","strokeLinecap":"round","strokeLinejoin":"round","children":[["$","path",null,{"d":"M4 19V5M4 19h16"}],["$","path",null,{"d":"m7 15 4-4 3 2 5-6"}]]}],["$","strong",null,{"children":"Costs & bills"}],["$","span",null,{"children":"Pricing, savings and electricity charges"}]]}],["$","a",null,{"href":"#questions","children":[["$","svg",null,{"aria-hidden":"true","className":"","fill":"none","viewBox":"0 0 24 24","stroke":"currentColor","strokeWidth":"1.8","strokeLinecap":"round","strokeLinejoin":"round","children":[["$","circle",null,{"cx":"12","cy":"12","r":"4"}],["$","path",null,{"d":"M12 2v2M12 20v2M4.93 4.93l1.42 1.42M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.42-1.42M17.66 6.34l1.41-1.41"}]]}],["$","strong",null,{"children":"Alberta conditions"}],["$","span",null,{"children":"Winter, snow and weather considerations"}]]}],["$","a",null,{"href":"#questions","children":[["$","svg",null,{"aria-hidden":"true","className":"","fill":"none","viewBox":"0 0 24 24","stroke":"currentColor","strokeWidth":"1.8","strokeLinecap":"round","strokeLinejoin":"round","children":"$L4"}],"$L5","$L6"]}]]}]]}]}],"$L7","$L8","$L9","$La","$Lb","$Lc","$Ld","$Le"],null,"$Lf"]}],"isPartial":false,"staleTime":300,"varyParams":null,"buildId":"NC5YO-LmdE20BBrIINIl2"}
